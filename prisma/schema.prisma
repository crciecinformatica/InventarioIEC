generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model usuarios {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome              String
  codigo_pessoa     String?
  email             String              @unique
  senha_hash        String
  perfil            String?             @default("viewer")
  ativo             Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  forum_comentarios forum_comentarios[]
  forum_reacoes     forum_reacoes[]
  forum_topicos     forum_topicos[]
  forum_arquivos    forum_arquivos[]
  forum_pastas      forum_pastas[]

  @@index([codigo_pessoa], map: "idx_usuarios_codigo_pessoa")
}

model solicitacoes_usuarios {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome            String
  codigo_pessoa   String
  email           String
  senha_hash      String
  status          String    @default("pendente")
  observacao      String?
  usuario_id      String?   @db.Uuid
  aprovado_por_id String?   @db.Uuid
  aprovado_por    String?
  aprovado_em     DateTime? @db.Timestamptz(6)
  rejeitado_por_id String?  @db.Uuid
  rejeitado_por   String?
  rejeitado_em    DateTime? @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([status], map: "idx_solicitacoes_usuarios_status")
  @@index([email], map: "idx_solicitacoes_usuarios_email")
  @@index([codigo_pessoa], map: "idx_solicitacoes_usuarios_codigo_pessoa")
}

model setores {
  id                    String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome                  String          @unique
  created_at            DateTime?       @default(now()) @db.Timestamptz(6)
  ativo                 Boolean         @default(true)
  descricao             String?
  aparelhos             aparelhos[]
  colaboradores         colaboradores[]
  impressoras           impressoras[]
  maquinas              maquinas[]
  notebooks_emprestados notebooks[]     @relation("EmprestimoSetor")
  notebooks             notebooks[]
  racks                 racks[]
  ramais                ramais[]

  @@index([ativo], map: "idx_setores_ativo")
  @@index([nome], map: "idx_setores_nome")
}

model localidades {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome          String          @unique
  ativo         Boolean         @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  aparelhos     aparelhos[]
  colaboradores colaboradores[]
  impressoras   impressoras[]
  maquinas      maquinas[]
  notebooks     notebooks[]
  racks         racks[]
  ramais        ramais[]

  @@index([ativo], map: "idx_localidades_ativo")
  @@index([nome], map: "idx_localidades_nome")
}

model colaboradores {
  id                    String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  codigo                Int?
  nome                  String
  status                status_colaborador    @default(Ativo)
  created_at            DateTime?             @default(now()) @db.Timestamptz(6)
  localidade_id         String?               @db.Uuid
  setor_id              String?               @db.Uuid
  alocacoes_aparelhos   alocacoes_aparelhos[]
  alocacoes_maquinas    alocacoes_maquinas[]
  alocacoes_notebooks   alocacoes_notebooks[]
  alocacoes_ramais      alocacoes_ramais[]
  localidade_rel        localidades?          @relation(fields: [localidade_id], references: [id], onUpdate: NoAction)
  setor_rel             setores?              @relation(fields: [setor_id], references: [id], onUpdate: NoAction)
  movimentacoes         movimentacoes[]
  notebooks_emprestados notebooks[]           @relation("EmprestimoColaborador")

  @@index([nome], map: "idx_colaboradores_nome")
  @@index([localidade_id], map: "idx_colaboradores_localidade_id")
}

model maquinas {
  id                 String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome_host          String?
  identificador      String?
  fabricante         String?
  modelo             String?
  categoria          categoria_equipamento?
  tipo               String?
  processador        String?
  memoria_ram        String?
  armazenamento      String?
  endereco_ip        String?
  localizacao        String?
  patrimonio_cpu     String?
  patrimonio_monitor String?
  data_revisao       DateTime?              @db.Date
  created_at         DateTime?              @default(now()) @db.Timestamptz(6)
  localidade_id      String?                @db.Uuid
  setor_id           String?                @db.Uuid
  alocacoes          alocacoes_maquinas[]
  localidade_rel     localidades?           @relation(fields: [localidade_id], references: [id], onUpdate: NoAction)
  setor_rel          setores?               @relation(fields: [setor_id], references: [id], onUpdate: NoAction)

  @@index([identificador], map: "idx_maquinas_identificador")
  @@index([localidade_id], map: "idx_maquinas_localidade_id")
}

model notebooks {
  id                        String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  modelo                    String?
  fabricante                String?
  categoria                 categoria_equipamento?
  processador               String?
  memoria                   String?
  armazenamento             String?
  numero_patrimonio         String?
  created_at                DateTime?              @default(now()) @db.Timestamptz(6)
  localidade_id             String?                @db.Uuid
  data_revisao              DateTime?              @db.Date
  emprestado                Boolean                @default(false)
  emprestado_colaborador_id String?                @db.Uuid
  emprestado_desde          DateTime?              @db.Date
  emprestado_obs            String?
  emprestado_setor_id       String?                @db.Uuid
  setor_id                  String?                @db.Uuid
  alocacoes                 alocacoes_notebooks[]
  emprestado_colaborador    colaboradores?         @relation("EmprestimoColaborador", fields: [emprestado_colaborador_id], references: [id], onUpdate: NoAction)
  emprestado_setor          setores?               @relation("EmprestimoSetor", fields: [emprestado_setor_id], references: [id], onUpdate: NoAction)
  localidade_rel            localidades?           @relation(fields: [localidade_id], references: [id], onUpdate: NoAction)
  setor_rel                 setores?               @relation(fields: [setor_id], references: [id], onUpdate: NoAction)

  @@index([emprestado_colaborador_id], map: "idx_notebooks_emprestado_colab")
  @@index([localidade_id], map: "idx_notebooks_localidade_id")
}

model aparelhos {
  id             String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  modelo         String?
  tipo           Int?
  chip           Boolean?              @default(false)
  endereco_ip    String?
  endereco_mac   String?
  status         Boolean?              @default(true)
  created_at     DateTime?             @default(now()) @db.Timestamptz(6)
  localidade_id  String?               @db.Uuid
  setor_id       String?               @db.Uuid
  alocacoes      alocacoes_aparelhos[]
  localidade_rel localidades?          @relation(fields: [localidade_id], references: [id], onUpdate: NoAction)
  setor_rel      setores?              @relation(fields: [setor_id], references: [id], onUpdate: NoAction)

  @@index([localidade_id], map: "idx_aparelhos_localidade_id")
}

model impressoras {
  id                 String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome_host          String?
  fabricante         String?
  modelo             String?
  numero_serie       String?
  endereco_ip        String?
  localidade         String?
  andar              String?
  servidor_impressao String?
  identificador_selb String?
  tipo_usuario       String?
  revisao            DateTime?    @db.Timestamptz(6)
  status             Boolean?     @default(true)
  created_at         DateTime?    @default(now()) @db.Timestamptz(6)
  localidade_id      String?      @db.Uuid
  setor_id           String?      @db.Uuid
  localidade_rel     localidades? @relation(fields: [localidade_id], references: [id], onUpdate: NoAction)
  setor_rel          setores?     @relation(fields: [setor_id], references: [id], onUpdate: NoAction)

  @@index([localidade_id], map: "idx_impressoras_localidade_id")
}

model ramais {
  id                  String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  numero_ramal        String?
  prefixo_telefonico  String?
  disponibilidade     String?
  fila                Boolean?           @default(false)
  contemplacao        Boolean?           @default(false)
  status_contemplacao Int?
  senha_acesso        String?
  created_at          DateTime?          @default(now()) @db.Timestamptz(6)
  localidade_id       String?            @db.Uuid
  password            String?
  setor_id            String?            @db.Uuid
  alocacoes           alocacoes_ramais[]
  localidade_rel      localidades?       @relation(fields: [localidade_id], references: [id], onUpdate: NoAction)
  setor_rel           setores?           @relation(fields: [setor_id], references: [id], onUpdate: NoAction)

  @@index([localidade_id], map: "idx_ramais_localidade_id")
}

model racks {
  id                      String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome_switch             String?
  marca_switch            String?
  localizacao             String?
  numero_patrimonio       String?
  quantidade_portas       Int?
  portas_em_uso           Int?
  portas_livres           Int?
  portas_academicas       String?
  portas_vlan_impressoras String?
  created_at              DateTime?    @default(now()) @db.Timestamptz(6)
  localidade_id           String?      @db.Uuid
  setor_id                String?      @db.Uuid
  localidade_rel          localidades? @relation(fields: [localidade_id], references: [id], onUpdate: NoAction)
  setor_rel               setores?     @relation(fields: [setor_id], references: [id], onUpdate: NoAction)

  @@index([localidade_id], map: "idx_racks_localidade_id")
}

model alocacoes_maquinas {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  colaborador_id String?        @db.Uuid
  maquina_id     String?        @db.Uuid
  data_inicio    DateTime?      @db.Date
  data_fim       DateTime?      @db.Date
  tipo_uso       Int?
  ativo          Boolean?       @default(true)
  created_at     DateTime?      @default(now()) @db.Timestamptz(6)
  colaborador    colaboradores? @relation(fields: [colaborador_id], references: [id], onUpdate: NoAction)
  maquina        maquinas?      @relation(fields: [maquina_id], references: [id], onUpdate: NoAction)

  @@index([colaborador_id], map: "idx_alocacoes_maquinas_colaborador")
  @@index([maquina_id], map: "idx_alocacoes_maquinas_maquina")
}

model alocacoes_notebooks {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  colaborador_id  String?        @db.Uuid
  notebook_id     String?        @db.Uuid
  data_inicio     DateTime?      @db.Date
  data_fim        DateTime?      @db.Date
  motivo_alocacao String?
  tipo_posse      Int?
  ativo           Boolean?       @default(true)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  colaborador     colaboradores? @relation(fields: [colaborador_id], references: [id], onUpdate: NoAction)
  notebook        notebooks?     @relation(fields: [notebook_id], references: [id], onUpdate: NoAction)

  @@index([colaborador_id], map: "idx_alocacoes_notebooks_colaborador")
}

model alocacoes_aparelhos {
  id                 String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  colaborador_id     String?        @db.Uuid
  aparelho_id        String?        @db.Uuid
  data_inicio        DateTime?      @db.Date
  data_fim           DateTime?      @db.Date
  descricao_alocacao String?
  motivo_alocacao    String?
  tipo_uso           Int?
  observacoes        String?
  ativo              Boolean?       @default(true)
  created_at         DateTime?      @default(now()) @db.Timestamptz(6)
  aparelho           aparelhos?     @relation(fields: [aparelho_id], references: [id], onUpdate: NoAction)
  colaborador        colaboradores? @relation(fields: [colaborador_id], references: [id], onUpdate: NoAction)

  @@index([colaborador_id], map: "idx_alocacoes_aparelhos_colaborador")
}

model alocacoes_ramais {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  colaborador_id  String?        @db.Uuid
  ramal_id        String?        @db.Uuid
  data_inicio     DateTime?      @db.Date
  data_fim        DateTime?      @db.Date
  tipo_base       Int?
  canal_adicional String?
  whatsapp        Boolean?       @default(false)
  ativo           Boolean?       @default(true)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  colaborador     colaboradores? @relation(fields: [colaborador_id], references: [id], onUpdate: NoAction)
  ramal           ramais?        @relation(fields: [ramal_id], references: [id], onUpdate: NoAction)

  @@index([colaborador_id], map: "idx_alocacoes_ramais_colaborador")
}

model movimentacoes {
  id                        String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  data_movimentacao         DateTime?      @db.Date
  identificador_dispositivo String?
  tipo_dispositivo          Int?
  tipo_movimentacao         Int?
  colaborador_id            String?        @db.Uuid
  setor                     String?
  tecnico_responsavel       String?
  observacao                String?
  created_at                DateTime?      @default(now()) @db.Timestamptz(6)
  colaborador               colaboradores? @relation(fields: [colaborador_id], references: [id], onUpdate: NoAction)
}

model solicitacoes {
  id                        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  data_criacao              DateTime? @db.Date
  colaborador_relacionado   String?
  identificador_dispositivo String?
  tipo_dispositivo          Int?
  tipo_solicitacao          Int?
  status_solicitacao        Int?
  prioridade                Int?
  origem_solicitacao        Int?
  solicitante               String?
  observacao                String?
  created_at                DateTime? @default(now()) @db.Timestamptz(6)
}

model solicitacoes_inventario {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  status            String    @default("pendente")
  tipo_recurso      String
  recurso_id        String?   @db.Uuid
  acao              String
  dados_anteriores  Json?
  dados_propostos   Json?
  comentarios       Json?     @default("[]")
  solicitante_id    String?   @db.Uuid
  solicitante_nome  String?
  revisor_id        String?   @db.Uuid
  revisor_nome      String?
  parecer           String?
  erro_aplicacao    String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  revisado_em       DateTime? @db.Timestamptz(6)

  @@index([status], map: "idx_solicitacoes_inventario_status")
  @@index([tipo_recurso], map: "idx_solicitacoes_inventario_tipo_recurso")
  @@index([solicitante_id], map: "idx_solicitacoes_inventario_solicitante")
  @@index([created_at(sort: Desc)], map: "idx_solicitacoes_inventario_created_at")
}

model audit_log {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tabela           String
  registro_id      String
  acao             String
  descricao        String?
  dados_anteriores Json?
  dados_novos      Json?
  usuario_id       String?   @db.Uuid
  usuario_nome     String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([tabela], map: "idx_audit_log_tabela")
  @@index([registro_id], map: "idx_audit_log_registro_id")
  @@index([created_at(sort: Desc)], map: "idx_audit_log_created_at")
}

model forum_topicos {
  id          String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  titulo      String
  conteudo    String
  autor_id    String?             @db.Uuid
  autor_nome  String
  fixado      Boolean             @default(false)
  fechado     Boolean             @default(false)
  views       Int                 @default(0)
  created_at  DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?           @default(now()) @db.Timestamptz(6)
  comentarios forum_comentarios[]
  autor       usuarios?           @relation(fields: [autor_id], references: [id])
  vinculos    forum_vinculos[]
  arquivos    forum_arquivos[]
}

model forum_comentarios {
  id         String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  topico_id  String           @db.Uuid
  autor_id   String?          @db.Uuid
  autor_nome String
  conteudo   String
  tipo        String           @default("permanente")
  expira_em   DateTime?        @db.Timestamptz(6)
  editado    Boolean          @default(false)
  created_at DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at DateTime?        @default(now()) @db.Timestamptz(6)
  autor      usuarios?        @relation(fields: [autor_id], references: [id])
  topico     forum_topicos    @relation(fields: [topico_id], references: [id], onDelete: Cascade)
  reacoes    forum_reacoes[]
  vinculos   forum_vinculos[]
  arquivos   forum_arquivos[]

  @@index([expira_em], map: "idx_forum_comentarios_expira_em")
}

model forum_vinculos {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  topico_id     String?            @db.Uuid
  comentario_id String?            @db.Uuid
  tipo_item     String
  item_id       String             @db.Uuid
  item_label    String
  created_at    DateTime?          @default(now()) @db.Timestamptz(6)
  comentario    forum_comentarios? @relation(fields: [comentario_id], references: [id], onDelete: Cascade)
  topico        forum_topicos?     @relation(fields: [topico_id], references: [id], onDelete: Cascade)

  @@index([tipo_item, item_id], map: "idx_forum_vinculos_item")
}

model forum_reacoes {
  id            String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  comentario_id String            @db.Uuid
  usuario_id    String            @db.Uuid
  tipo          String
  created_at    DateTime?         @default(now()) @db.Timestamptz(6)
  comentario    forum_comentarios @relation(fields: [comentario_id], references: [id], onDelete: Cascade)
  usuario       usuarios          @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@unique([comentario_id, usuario_id, tipo])
}

model forum_arquivos {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  topico_id        String?            @db.Uuid
  comentario_id    String?            @db.Uuid
  usuario_id       String?            @db.Uuid
  pasta_id         String?            @db.Uuid
  tipo_arquivo     String             // MIME type: image/jpeg, image/png, application/pdf
  nome_original    String             // Original filename
  nome_armazenado  String             // Path in Supabase Storage
  tamanho_bytes    Int
  url_publica      String             // Public URL to access the file
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  comentario       forum_comentarios? @relation(fields: [comentario_id], references: [id], onDelete: Cascade)
  topico           forum_topicos?     @relation(fields: [topico_id], references: [id], onDelete: Cascade)
  usuario          usuarios?          @relation(fields: [usuario_id], references: [id], onDelete: SetNull)
  pasta            forum_pastas?      @relation(fields: [pasta_id], references: [id], onDelete: SetNull)

  @@index([topico_id], map: "idx_forum_arquivos_topico_id")
  @@index([comentario_id], map: "idx_forum_arquivos_comentario_id")
  @@index([usuario_id], map: "idx_forum_arquivos_usuario_id")
  @@index([pasta_id], map: "idx_forum_arquivos_pasta_id")
}

model forum_pastas {
  id          String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome        String
  descricao   String?
  parent_id   String?            @db.Uuid
  criado_por  String?            @db.Uuid
  cor         String?            @default("#3b82f6")
  created_at  DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?          @default(now()) @db.Timestamptz(6)
  parent      forum_pastas?      @relation("SubPastas", fields: [parent_id], references: [id], onDelete: Cascade)
  filhos      forum_pastas[]     @relation("SubPastas")
  arquivos    forum_arquivos[]
  criador     usuarios?          @relation(fields: [criado_por], references: [id], onDelete: SetNull)

  @@index([parent_id], map: "idx_forum_pastas_parent_id")
  @@index([criado_por], map: "idx_forum_pastas_criado_por")
}

enum categoria_equipamento {
  Administrativa
  Academica
  Backup
}

enum status_colaborador {
  Ativo
  Inativo
}
